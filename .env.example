# Krea 2 Studio configuration
# Copy to .env and fill in values

# Hugging Face token (optional; useful for higher rate limits or gated downloads)
HF_TOKEN=

# Paths to downloaded checkpoint files. Leave blank to auto-detect files under models/krea2.
KREA2_TURBO_PATH=
KREA2_RAW_PATH=

# Output directory for generated images
OUTPUT_DIR=outputs

# Auto-load this checkpoint when run.bat starts (leave blank to disable)
KREA2_AUTO_CHECKPOINT=
KREA2_AUTO_QUANT=bf16

# AI helper backend for magic wand/image-to-prompt: local | openrouter | ideogram-json
# local uses the bundled Qwen3-VL support model; OpenRouter/Ideogram are optional hosted helpers.
PROMPT_EXPANDER_BACKEND=local
IDEOGRAM_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-4-31b-it:free
OPENROUTER_FREE_ONLY=true
